4. Implement a program to check if a number is an Armstrong Number.
#include <stdio.h>
int main()
{
    int n, temp, digit, sum = 0;
    printf("Enter a number: ");
    scanf("%d", &n);
    temp = n;  
    while(n > 0)
    {
        digit = n % 10;             
        sum = sum + (digit * digit * digit);  
        n = n / 10;                  
    }
    if(sum == temp)
        printf("This is an Armstrong number\n");
    else
        printf("This is not an Armstrong number\n");
    return 0;
}
5. Write a program to generate all Prime Numbers between 1 and 100.
#include<stdio.h>
int main()
{
    int i, j, count;
    for(i = 2; i <= 100; i++)
    {
        count = 0;
        for(j = 1; j <= i; j++)
        {
            if(i % j == 0)
                count++;
        }
        if(count == 2)
            printf("%d ", i);
    }
    return 0;
}
6. Create a program to sort an array of 5 integers in ascending order (Bubble Sort).
#include<stdio.h>
int main()
{
    int a[5], i, j, temp;
    for(i=0;i<5;i++)
        scanf("%d",&a[i]);
    for(i=0;i<5;i++)
    {
        for(j=0;j<4;j++)
        {
            if(a[j] > a[j+1])
            {
                temp = a[j];
                a[j] = a[j+1];
                a[j+1] = temp;
            }
        }
    }
    for(i=0;i<5;i++)
        printf("%d ", a[i]);
    return 0;
}
