Looping Statements (For, While, Do-While)
16.Write a program to calculate the sum of the first N natural numbers using a while loop.
#include<stdio.h>
int main()
{
    int n,sum=0;
    scanf("%d",&n);
    while(n>=0)
   {
    sum=n+sum;
    n--;
   }
   printf("the sum of natural number is: %d\n",sum);
   return 0;
}
17.Implement a program to display the Fibonacci series up to a given number of terms using a for loop.
#include<stdio.h>
int main()
{
    int a=0,b=1,c,n;
    scanf("%d",&n);
    printf("%d\n",a);
    printf("%d\n",b);
    while(n>0)
    {
        c=a+b;
        printf("%d\n",c);
        a=b;
        b=c;
        n--;  
    }
   
   return 0;
}
