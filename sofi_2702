14.Create a calculator using the switch statement that takes an operator (+, -, *, /, %) and two integer operands from the user.
#include <stdio.h>
int main() {
    int a, b;
    char op;
    printf("Enter first integer: ");
    scanf("%d", &a);
    printf("Enter second integer: ");
    scanf("%d", &b);
    printf("Enter an operator: ");
    scanf(" %c", &op); 
    switch (op) {
        case '+':
            printf("Result = %d\n", a + b);
            break;
        case '-':
            printf("Result = %d\n", a - b);
            break;
        case '*':
            printf("Result = %d\n", a * b);
            break;
        case '/':
            printf("Result = %d\n", a / b);
            break;
        case '%':
            printf("Result = %d\n", a % b);
            break;
        default:
            printf("Invalid operator\n");
    }

    return 0;
}
15.Write a program to print the names of the days of the week based on an input number (1 for Monday, 2 for Tuesday, etc.) using switch. Include a default case for invalid inputs.
